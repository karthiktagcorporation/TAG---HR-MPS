NODE_ENV=development
PORT=4000

# Local development DB (adjust to your local Postgres)
DATABASE_URL=postgresql://tagmps:tagmps@localhost:5432/tagmps?schema=public

JWT_ACCESS_SECRET=dev_access_secret_change_me_to_long_random
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_to_long_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:5173

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

SUPER_ADMIN_NAME=TAG Super Admin
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@tagcorporation.net
SUPER_ADMIN_PASSWORD=ChangeMe@12345

SEED_SAMPLE_DATA=true
