# ─────────────────────────────────────────────────────────────
# TAG - MPS : Root environment example
# Copy to .env for docker-compose, and into backend/.env / frontend/.env
# for local non-docker development.
# ─────────────────────────────────────────────────────────────

# ===== PostgreSQL =====
POSTGRES_USER=tagmps
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=tagmps
POSTGRES_PORT=5432

# Connection string consumed by Prisma / backend.
# When running with docker-compose use host "postgres" (the service name).
# When running backend locally against a local DB use "localhost".
DATABASE_URL=postgresql://tagmps:change_me_strong_password@postgres:5432/tagmps?schema=public

# ===== Backend =====
NODE_ENV=production
BACKEND_PORT=4000

# JWT secrets - MUST be long random strings in production
JWT_ACCESS_SECRET=replace_with_64_char_random_string_access
JWT_REFRESH_SECRET=replace_with_64_char_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Rate limiting (auth endpoints)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Initial Super Admin (created by the seed script)
SUPER_ADMIN_NAME=TAG Super Admin
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@tagcorporation.net
SUPER_ADMIN_PASSWORD=ChangeMe@12345

# Seed sample/demo data (plans, actuals, notifications) for development.
# Set to "false" for a clean production database.
SEED_SAMPLE_DATA=true

# ===== Frontend =====
FRONTEND_PORT=8080
# Base URL the browser uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:4000/api
VITE_APP_NAME=TAG - MPS
